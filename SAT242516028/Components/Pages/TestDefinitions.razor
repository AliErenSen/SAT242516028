@page "/test-definitions"
@using Microsoft.AspNetCore.Authorization
@using MyDbModels
@using Entities
@using Services
@attribute [Authorize]
@inject ILabService LabService
@inject IReportService ReportService
@inject IJSRuntime JS
@rendermode InteractiveServer

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>Test Tanımları</h3>
        <div class="d-flex gap-2">
            <button class="btn btn-secondary" @onclick="DownloadPdf">
                <i class="bi bi-file-earmark-pdf"></i> PDF Rapor
            </button>
            <button class="btn btn-primary" @onclick="OpenCreateForm">
                <i class="bi bi-plus-lg"></i> Yeni Test Ekle
            </button>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @ErrorMessage
            <button type="button" class="btn-close" @onclick="() => ErrorMessage = null"></button>
        </div>
    }

    <div class="card mb-3">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <input type="text" class="form-control" placeholder="Test Adı veya Kodu ara..."
                           @bind="SearchText" @bind:event="oninput" @onkeyup="SearchData" />
                </div>
            </div>
        </div>
    </div>

    @if (ShowForm)
    {
        <div class="card border-primary mb-3">
            <div class="card-header bg-primary text-white">
                @(CurrentTest.Id > 0 ? "Testi Düzenle" : "Yeni Test Tanımı")
            </div>
            <div class="card-body">
                <EditForm Model="CurrentTest" OnValidSubmit="SaveTest" FormName="TestForm">
                    <DataAnnotationsValidator />
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Test Kodu</label>
                            <InputText @bind-Value="CurrentTest.Code" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Test Adı</label>
                            <InputText @bind-Value="CurrentTest.Name" class="form-control" />
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Birim (Örn: mg/dL)</label>
                            <InputText @bind-Value="CurrentTest.Unit" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Fiyat (₺)</label>
                            <InputNumber @bind-Value="CurrentTest.Price" class="form-control" />
                        </div>
                    </div>

                    <button type="submit" class="btn btn-success">Kaydet</button>
                    <button type="button" class="btn btn-secondary" @onclick="CancelForm">İptal</button>
                </EditForm>
            </div>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th style="cursor:pointer" @onclick='() => SortData("Code")'>Kod</th>
                        <th style="cursor:pointer" @onclick='() => SortData("Name")'>Test Adı</th>
                        <th>Birim</th>
                        <th style="cursor:pointer" @onclick='() => SortData("Price")'>Fiyat</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (DbModel?.Items != null)
                    {
                        @foreach (var item in DbModel.Items)
                        {
                            <tr>
                                <td>@item.Code</td>
                                <td>@item.Name</td>
                                <td>@item.Unit</td>
                                <td>@item.Price.ToString("C2")</td>
                                <td>
                                    <button class="btn btn-sm btn-warning me-1" @onclick="() => EditTest(item)">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <button class="btn btn-sm btn-danger" @onclick="() => DeleteTest(item.Id)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="5" class="text-center">Yükleniyor...</td></tr>
                    }
                </tbody>
            </table>
        </div>

        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-center">
                <li class="page-item @(DbModel.Parameters.PageNumber <= 1 ? "disabled" : "")">
                    <button class="page-link" @onclick="() => ChangePage(DbModel.Parameters.PageNumber - 1)">Önceki</button>
                </li>
                <li class="page-item disabled"><span class="page-link">Sayfa @DbModel.Parameters.PageNumber / @DbModel.Parameters.TotalPageCount</span></li>
                <li class="page-item @(DbModel.Parameters.PageNumber >= DbModel.Parameters.TotalPageCount ? "disabled" : "")">
                    <button class="page-link" @onclick="() => ChangePage(DbModel.Parameters.PageNumber + 1)">Sonraki</button>
                </li>
            </ul>
        </nav>
    }
</div>

@code {
    // BURADA Entities.TestDefinitions KULLANARAK ÇAKIŞMAYI ÖNLEDİK
    private IMyDbModel<Entities.TestDefinitions> DbModel { get; set; } = new MyDbModel<Entities.TestDefinitions>();
    private Entities.TestDefinitions CurrentTest { get; set; } = new();

    private bool ShowForm { get; set; } = false;
    private string SearchText { get; set; } = "";
    private string ErrorMessage { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            if (!string.IsNullOrEmpty(SearchText))
            {
                if (DbModel.Parameters.Where.ContainsKey("Name"))
                    DbModel.Parameters.Where["Name"] = SearchText;
                else
                    DbModel.Parameters.Where.Add("Name", SearchText);
            }
            else
            {
                if (DbModel.Parameters.Where.ContainsKey("Name"))
                    DbModel.Parameters.Where.Remove("Name");
            }

            DbModel = await LabService.GetTestList(DbModel);
        }
        catch (Exception ex)
        {
            ErrorMessage = "Hata: " + ex.Message;
        }
    }

    private async Task SearchData()
    {
        DbModel.Parameters.PageNumber = 1;
        await LoadData();
    }

    private async Task ChangePage(int page)
    {
        DbModel.Parameters.PageNumber = page;
        await LoadData();
    }

    private async Task SortData(string col)
    {
        DbModel.Parameters.OrderBy = col;
        await LoadData();
    }

    private void OpenCreateForm()
    {
        CurrentTest = new Entities.TestDefinitions();
        ShowForm = true;
    }

    private void EditTest(Entities.TestDefinitions test)
    {
        CurrentTest = new Entities.TestDefinitions
            {
                Id = test.Id,
                Code = test.Code,
                Name = test.Name,
                Unit = test.Unit,
                Price = test.Price,
                IsActive = test.IsActive
            };
        ShowForm = true;
    }

    private async Task SaveTest()
    {
        try
        {
            await LabService.SaveTest(CurrentTest);
            ShowForm = false;
            await LoadData();
        }
        catch (Exception ex)
        {
            ErrorMessage = "Kaydetme hatası: " + ex.Message;
        }
    }

    private void CancelForm()
    {
        ShowForm = false;
        CurrentTest = new Entities.TestDefinitions();
    }

    private async Task DeleteTest(int id)
    {
        try
        {
            await LabService.DeleteTest(id);
            await LoadData();
        }
        catch (Exception ex)
        {
            ErrorMessage = "Silme hatası: " + ex.Message;
        }
    }

    private async Task DownloadPdf()
    {
        try
        {
            var pdfBytes = ReportService.GenerateTestDefReport(DbModel.Items);
            using var stream = new MemoryStream(pdfBytes);
            using var streamRef = new DotNetStreamReference(stream);
            await JS.InvokeVoidAsync("downloadFileFromStream", $"TestListesi_{DateTime.Now:yyyyMMdd}.pdf", streamRef);
        }
        catch (Exception ex)
        {
            ErrorMessage = "Rapor hatası: " + ex.Message;
        }
    }
}