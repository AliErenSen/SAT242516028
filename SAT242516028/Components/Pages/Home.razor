@page "/"
@using Microsoft.AspNetCore.Authorization
@using Services
@using Entities
@using ApexCharts
@* AŞAĞIDAKİ SATIR SAYESİNDE GİRİŞ YAPMAYAN BURAYI GÖREMEZ, LOGİNE GİDER *@
@attribute [Authorize]
@inject ILabService LabService

<PageTitle>Dashboard</PageTitle>

xxxxxxxxxxxxxxxxxx


@* Kullanıcı bilgilerine (Ad, Soyad vb.) erişmek için AuthorizeView kullanıyoruz *@
<AuthorizeView>
    <div class="container mt-4">
        <h2 class="mb-4">Hoş Geldiniz, <span class="text-primary">@context.User.Identity?.Name</span></h2>

        @if (Stats == null)
        {
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Yükleniyor...</span>
            </div>
        }
        else
        {
            @* --- KARTLAR (ÖZET BİLGİLER) --- *@
            <div class="row mb-4">
                <div class="col-md-6">
                    <div class="card bg-primary text-white shadow-sm">
                        <div class="card-body text-center">
                            <h1 class="display-4 fw-bold">@Stats.TotalPatients</h1>
                            <p class="fs-5">Toplam Hasta Sayısı</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card bg-success text-white shadow-sm">
                        <div class="card-body text-center">
                            <h1 class="display-4 fw-bold">@Stats.TotalTests</h1>
                            <p class="fs-5">Tanımlı Test Sayısı</p>
                        </div>
                    </div>
                </div>
            </div>

            @* --- GRAFİK ALANI --- *@
            <div class="card shadow-sm">
                <div class="card-header">
                    <h5>Sistem Özeti Grafiği</h5>
                </div>
                <div class="card-body">
                    <ApexChart TItem="ChartData"
                               Title="Veri Dağılımı"
                               Options="ChartOptions">

                        <ApexPointSeries TItem="ChartData"
                                         Items="MyChartData"
                                         Name="Adet"
                                         SeriesType="SeriesType.Bar"
                                         XValue="e => e.Category"
                                         YValue="e => e.Count"
                                         Color="#0d6efd" />
                    </ApexChart>
                </div>
            </div>
        }
    </div>
</AuthorizeView>

@code {
    private DashboardStats Stats;
    private List<ChartData> MyChartData = new();
    private ApexChartOptions<ChartData> ChartOptions = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Veritabanından verileri çek
            Stats = await LabService.GetDashboardStats();

            // Grafiğe verileri yükle
            MyChartData.Add(new ChartData { Category = "Hastalar", Count = Stats.TotalPatients });
            MyChartData.Add(new ChartData { Category = "Testler", Count = Stats.TotalTests });

            // Grafik ayarları
            ChartOptions.PlotOptions = new PlotOptions
                {
                    Bar = new PlotOptionsBar
                    {
                        Horizontal = false,
                        ColumnWidth = "50%"
                    }
                };
        }
        catch (Exception)
        {
            // Hata olursa boş veri gösterelim ki sayfa patlamasın
            Stats = new DashboardStats();
        }
    }

    public class ChartData
    {
        public string Category { get; set; }
        public int Count { get; set; }
    }
}
