@page "/patients"
@using Microsoft.AspNetCore.Authorization
@using MyDbModels
@using Entities
@using Services
@using Microsoft.Extensions.Localization
@using SAT242516028.Resources  @* DÜZELTİLDİ: Klasör adın Resources olduğu için burası Resources olmalı *@
@attribute [Authorize]

@inject IPatientService PatientService
@inject NavigationManager NavManager
@inject IReportService ReportService
@inject IJSRuntime JS
@inject IStringLocalizer<SharedResource> Loc
@rendermode InteractiveServer

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>Hasta Yönetimi</h3>
        <div class="d-flex gap-2">
            <button class="btn btn-secondary" @onclick="DownloadPdf">
                <i class="bi bi-file-earmark-pdf"></i> PDF Rapor
            </button>
            <button class="btn btn-primary" @onclick="OpenCreateForm">
                <i class="bi bi-plus-lg"></i> @Loc["AddNew"]
            </button>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @ErrorMessage
            <button type="button" class="btn-close" @onclick="() => ErrorMessage = null"></button>
        </div>
    }

    @* --- ARAMA --- *@
    <div class="card mb-3">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <input type="text" class="form-control" placeholder="@Loc["Name"] ile ara..."
                           @bind="SearchText" @bind:event="oninput" @onkeyup="SearchData" />
                </div>
                <div class="col-md-2">
                    <select class="form-select" @onchange="OnPageSizeChanged">
                        <option value="5">5 Satır</option>
                        <option value="10" selected>10 Satır</option>
                        <option value="20">20 Satır</option>
                    </select>
                </div>
            </div>
        </div>
    </div>

    @* --- LİSTE VEYA FORM --- *@
    @if (ShowForm)
    {
        <div class="card border-primary mb-3">
            <div class="card-header bg-primary text-white">
                @(CurrentPatient.Id > 0 ? Loc["Update"] : Loc["AddNew"])
            </div>
            <div class="card-body">
                <EditForm Model="CurrentPatient" OnValidSubmit="SavePatient" FormName="PatientForm">
                    <DataAnnotationsValidator />
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">@Loc["TcNumber"]</label>
                            <InputText @bind-Value="CurrentPatient.TCNumber" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">@Loc["Name"]</label>
                            <InputText @bind-Value="CurrentPatient.FirstName" class="form-control" />
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">@Loc["Surname"]</label>
                            <InputText @bind-Value="CurrentPatient.LastName" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Telefon</label>
                            <InputText @bind-Value="CurrentPatient.Phone" class="form-control" />
                        </div>
                    </div>

                    <button type="submit" class="btn btn-success">@Loc["Save"]</button>
                    <button type="button" class="btn btn-secondary" @onclick="CancelForm">@Loc["Cancel"]</button>
                </EditForm>
            </div>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th style="cursor:pointer" @onclick='() => SortData("TCNumber")'>@Loc["TcNumber"]</th>
                        <th style="cursor:pointer" @onclick='() => SortData("FirstName")'>@Loc["Name"]</th>
                        <th style="cursor:pointer" @onclick='() => SortData("LastName")'>@Loc["Surname"]</th>
                        <th>Telefon</th>
                        <th>@Loc["Operations"]</th>
                    </tr>
                </thead>
                <tbody>
                    @if (DbModel?.Items != null)
                    {
                        @foreach (var item in DbModel.Items)
                        {
                            <tr>
                                <td>@item.TCNumber</td>
                                <td>@item.FirstName</td>
                                <td>@item.LastName</td>
                                <td>@item.Phone</td>
                                <td>
                                    <button class="btn btn-sm btn-warning me-1" @onclick="() => EditPatient(item)">
                                        <i class="bi bi-pencil"></i> @Loc["Update"]
                                    </button>
                                    <button class="btn btn-sm btn-danger" @onclick="() => DeletePatient(item.Id)">
                                        <i class="bi bi-trash"></i> @Loc["Delete"]
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="5" class="text-center">Yükleniyor veya veri yok...</td></tr>
                    }
                </tbody>
            </table>
        </div>

        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-center">
                <li class="page-item @(DbModel.Parameters.PageNumber <= 1 ? "disabled" : "")">
                    <button class="page-link" @onclick="() => ChangePage(DbModel.Parameters.PageNumber - 1)">Önceki</button>
                </li>
                <li class="page-item disabled"><span class="page-link">Sayfa @DbModel.Parameters.PageNumber / @DbModel.Parameters.TotalPageCount</span></li>
                <li class="page-item @(DbModel.Parameters.PageNumber >= DbModel.Parameters.TotalPageCount ? "disabled" : "")">
                    <button class="page-link" @onclick="() => ChangePage(DbModel.Parameters.PageNumber + 1)">Sonraki</button>
                </li>
            </ul>
        </nav>
    }
</div>

@code {
    private IMyDbModel<Entities.Patients> DbModel { get; set; } = new MyDbModel<Entities.Patients>();
    private Entities.Patients CurrentPatient { get; set; } = new();

    private bool ShowForm { get; set; } = false;
    private string SearchText { get; set; } = "";
    private string ErrorMessage { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            if (!string.IsNullOrEmpty(SearchText))
            {
                if (DbModel.Parameters.Where.ContainsKey("FirstName"))
                    DbModel.Parameters.Where["FirstName"] = SearchText;
                else
                    DbModel.Parameters.Where.Add("FirstName", SearchText);
            }
            else
            {
                if (DbModel.Parameters.Where.ContainsKey("FirstName"))
                    DbModel.Parameters.Where.Remove("FirstName");
            }

            DbModel = await PatientService.GetList(DbModel);
        }
        catch (Exception ex)
        {
            ErrorMessage = "Veri yüklenirken hata oluştu: " + ex.Message;
        }
    }

    private async Task SearchData()
    {
        DbModel.Parameters.PageNumber = 1;
        await LoadData();
    }

    private async Task ChangePage(int page)
    {
        DbModel.Parameters.PageNumber = page;
        await LoadData();
    }

    private async Task OnPageSizeChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value.ToString(), out int size))
        {
            DbModel.Parameters.PageSize = size;
            DbModel.Parameters.PageNumber = 1;
            await LoadData();
        }
    }

    private async Task SortData(string columnName)
    {
        DbModel.Parameters.OrderBy = columnName;
        await LoadData();
    }

    private void OpenCreateForm()
    {
        CurrentPatient = new Entities.Patients();
        ShowForm = true;
        ErrorMessage = null;
    }

    private void EditPatient(Entities.Patients patient)
    {
        CurrentPatient = new Entities.Patients
            {
                Id = patient.Id,
                TCNumber = patient.TCNumber,
                FirstName = patient.FirstName,
                LastName = patient.LastName,
                Phone = patient.Phone,
                Gender = patient.Gender,
                BirthDate = patient.BirthDate
            };
        ShowForm = true;
    }

    private async Task SavePatient()
    {
        try
        {
            await PatientService.Save(CurrentPatient);
            ShowForm = false;
            await LoadData();
        }
        catch (Exception ex)
        {
            ErrorMessage = "Kaydetme hatası: " + ex.Message;
        }
    }

    private void CancelForm()
    {
        ShowForm = false;
        CurrentPatient = new Entities.Patients();
    }

    private async Task DeletePatient(int id)
    {
        try
        {
            await PatientService.Delete(id);
            await LoadData();
        }
        catch (Exception ex)
        {
            ErrorMessage = "Silme hatası: " + ex.Message;
        }
    }

    private async Task DownloadPdf()
    {
        try
        {
            var pdfBytes = ReportService.GeneratePatientReport(DbModel.Items);
            using var stream = new MemoryStream(pdfBytes);
            using var streamRef = new DotNetStreamReference(stream);
            await JS.InvokeVoidAsync("downloadFileFromStream", $"HastaListesi_{DateTime.Now:yyyyMMdd_HHmm}.pdf", streamRef);
        }
        catch (Exception ex)
        {
            ErrorMessage = "Rapor oluşturma hatası: " + ex.Message;
        }
    }
}